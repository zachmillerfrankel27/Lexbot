# ── Anthropic (required) ──────────────────────────────────────
# Get this at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (optional but recommended) ────────────────────
# Get this at: https://elevenlabs.io → Profile → API Key
# Without this, the app falls back to browser speech synthesis
ELEVENLABS_API_KEY=...

# Voice ID — default is "Adam" (deep male voice, professional)
# Browse voices at: https://elevenlabs.io/voice-library
# Other good options:
#   Daniel (authoritative):  onwK4e9ZLuTAKqWW03F9
#   Josh (friendly):         TxGEqnHWrfWFTfGW9XjX
#   Rachel (female):         21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
